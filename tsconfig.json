{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "node",
		"target": "ES2022",
		"lib": [
			"es2020",
			"es2021",
			"es2022",
			"esNext.Intl",
			"es2023",
			"es2024",
		],
		"strict": true,
		"outDir": "./out/",
		"rootDir": ".",
		"resolveJsonModule": true,
		"erasableSyntaxOnly": true,
		"allowSyntheticDefaultImports": true,
	},
	"exclude": ["node_modules"],
}
